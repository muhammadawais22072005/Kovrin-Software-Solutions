{
  "entities": {
    "inquiry": {
      "title": "Inquiry",
      "description": "Represents a potential client solutions inquiry submission",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the prospect"
        },
        "contactNumber": {
          "type": "string",
          "description": "Contact number of the prospect"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the prospect"
        },
        "description": {
          "type": "string",
          "description": "Summary of custom web or neural agent requirements"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Database or server generation timestamp"
        }
      },
      "required": ["name", "contactNumber", "email", "description", "createdAt"]
    }
  },
  "firestore": {
    "inquiries/{inquiryId}": {
      "schema": "inquiry",
      "description": "Inbound solutions requests database collection"
    }
  }
}
